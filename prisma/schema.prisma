datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Tabela de Usuário (Perfil)
model User {
  id            String    @id @default(cuid())
  name          String?
  username      String?   @unique
  email         String?   @unique
  password      String?
  emailVerified DateTime?
  image         String?
  description   String?   @db.Text
  linkedinUrl   String?
  instagramUrl  String?
  githubUrl     String?
  orcidUrl     String?
  lattesUrl     String?
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  news          News[]
}

// Tabela de Contas OAuth (Google, GitHub, etc)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// Tabela de Sessões (Para login persistente)
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model News {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique // URL amigável (ex: /noticias/minha-primeira-noticia)
  resume    String?  // Um breve resumo para o card de listagem
  content   String   @db.Text // O corpo da notícia em Markdown puro
  published Boolean  @default(false) // Permite salvar como rascunho
  coverImage String?  //
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  authorId  String
  author    User     @relation(fields: [authorId], references: [id]) // Chave estrangeira
}